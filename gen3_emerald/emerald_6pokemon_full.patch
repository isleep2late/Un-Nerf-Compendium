+// any-ability: returns the custom ability stored at PK3 0x1E (mon->box.unknown), else species default
+u8 GetBattlerStoredOrSpeciesAbility(u8 battler)
+{
+    struct Pokemon *mon = (GetBattlerSide(battler) == B_SIDE_PLAYER)
+        ? &gPlayerParty[gBattlerPartyIndexes[battler]]
+        : &gEnemyParty[gBattlerPartyIndexes[battler]];
+    u8 storedAbility = mon->box.unknown & 0xFF;
+    if (storedAbility != ABILITY_NONE)
+    {
+        gLastUsedAbility = storedAbility;
+        return storedAbility;
+    }
+    return GetAbilityBySpecies(gBattleMons[battler].species, gBattleMons[battler].abilityNum);
